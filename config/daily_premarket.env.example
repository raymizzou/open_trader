# Local template for daily premarket automation.
# Copy to config/daily_premarket.env and replace the placeholder API key locally.

OPEN_TRADER_REPO=/Users/ray/projects/open_trader
OPEN_TRADER_PYTHON=/Users/ray/projects/open_trader/.venv/bin/python
OPEN_TRADER_TIMEZONE=Asia/Shanghai
# HK daily workflow deadline is fixed by code at 09:00 Asia/Shanghai.
# US daily workflow uses OPEN_TRADER_DEADLINE.
OPEN_TRADER_DEADLINE=21:10
OPEN_TRADER_FUTU_HOST=127.0.0.1
OPEN_TRADER_FUTU_PORT=11111

OPEN_TRADER_DATA_DIR=data
OPEN_TRADER_REPORTS_DIR=reports
OPEN_TRADER_LOGS_DIR=logs
OPEN_TRADER_PORTFOLIO=data/latest/portfolio.csv
OPEN_TRADER_EASTMONEY_STATEMENT=
OPEN_TRADER_EASTMONEY_PDF_PASSWORD=
OPEN_TRADER_MAX_WORKERS=4
OPEN_TRADER_TA_TIMEOUT_SECONDS=600
OPEN_TRADER_TA_MAX_RETRIES=2
OPEN_TRADER_TRADINGAGENTS_PATH=/Users/ray/projects/TradingAgents
OPEN_TRADER_CLASSIFIER_MODEL=deepseek-v4-flash
OPEN_TRADER_NOTIFIERS=feishu_app,macos
OPEN_TRADER_FEISHU_APP_ID=cli_replace_me
OPEN_TRADER_FEISHU_APP_SECRET=replace-me
OPEN_TRADER_FEISHU_RECEIVE_ID_TYPE=email
OPEN_TRADER_FEISHU_RECEIVE_ID=replace@example.com
# Optional webhook notifier alternative:
# OPEN_TRADER_NOTIFIERS=feishu,macos
# OPEN_TRADER_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/example
# Optional Xiaoai native voice notifier:
# OPEN_TRADER_NOTIFIERS=feishu_app,xiaoai
# OPEN_TRADER_XIAOAI_HOST=192.168.1.107
# OPEN_TRADER_XIAOAI_SSH_KEY=~/.ssh/open_trader_xiaoai
OPEN_TRADER_FEISHU_MESSAGE_FORMAT=text
OPEN_TRADER_NOTIFY_DAILY_REPORT=1
OPEN_TRADER_NOTIFY_ACTION_TRIGGERS=1

DEEPSEEK_API_KEY=replace-me
TREND_ANIMALS_API_KEY=
TREND_ANIMALS_WARM_TO_HOT_A_SHARE_TM_ID=622466
TREND_ANIMALS_WARM_TO_HOT_ETF_TM_ID=697199
TREND_ANIMALS_WARM_TO_HOT_US_TM_IDS=622460
TREND_ANIMALS_WARM_TO_HOT_HK_TM_IDS=622494
# Only existing positions explicitly classified as short-term trend belong here.
OPEN_TRADER_TREND_US_SYMBOLS=
OPEN_TRADER_TREND_HK_SYMBOLS=

# Dedicated Futu simulate accounts and calibrated all-in target-broker costs.
OPEN_TRADER_TREND_REVIEW_CN_SIMULATE_ACC_ID=
OPEN_TRADER_TREND_REVIEW_US_SIMULATE_ACC_ID=
OPEN_TRADER_TREND_REVIEW_HK_SIMULATE_ACC_ID=
OPEN_TRADER_TREND_REVIEW_CN_BUY_COST_BPS=
OPEN_TRADER_TREND_REVIEW_CN_SELL_COST_BPS=
OPEN_TRADER_TREND_REVIEW_US_BUY_COST_BPS=
OPEN_TRADER_TREND_REVIEW_US_SELL_COST_BPS=
OPEN_TRADER_TREND_REVIEW_HK_BUY_COST_BPS=
OPEN_TRADER_TREND_REVIEW_HK_SELL_COST_BPS=
